{
  "name": "sweetlink",
  "version": "0.2.0",
  "private": false,
  "description": "Controlled-browser automation CLI for SweetLink sessions.",
  "keywords": [
    "automation",
    "browser",
    "cli",
    "devtools",
    "sweetlink"
  ],
  "homepage": "https://github.com/steipete/sweetlink",
  "bugs": {
    "url": "https://github.com/steipete/sweetlink/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/steipete/sweetlink.git",
    "directory": "apps/sweetlink"
  },
  "bin": {
    "sweetlink": "./dist/src/index.js",
    "sweetlinkd": "./dist/daemon/src/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./runtime/browser": {
      "types": "./dist/src/runtime/browser/index.d.ts",
      "import": "./dist/src/runtime/browser/index.js",
      "default": "./dist/src/runtime/browser/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsgo --project tsconfig.build.json",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsgo --project tsconfig.json --noEmit",
    "format": "oxfmt --write ./src ./shared/src ./daemon/src ./tests package.json tsconfig.json tsconfig.build.json tsconfig.base.json vitest.config.ts",
    "format:check": "oxfmt --check ./src ./shared/src ./daemon/src ./tests package.json tsconfig.json tsconfig.build.json tsconfig.base.json vitest.config.ts",
    "lint": "pnpm format:check && oxlint --deny-warnings ./src ./shared/src ./daemon/src ./tests",
    "lint:fix": "pnpm format && oxlint --fix ./src ./shared/src ./daemon/src ./tests",
    "standalone:post-sync": "tsx scripts/post-sync.ts",
    "prepublishOnly": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@steipete/sweet-cookie": "0.2.0",
    "arkregex": "^0.0.5",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "es-toolkit": "^1.46.1",
    "html2canvas": "^1.4.1",
    "playwright-core": "^1.59.1",
    "puppeteer": "^24.42.0",
    "random-word-slugs": "^0.1.7",
    "tldjs": "^2.3.2",
    "undici": "^8.2.0",
    "ws": "^8.20.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260503.1",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "ultracite": "^7.6.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.16.0"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "puppeteer",
      "tldjs"
    ],
    "overrides": {
      "node-gyp": "12.1.0"
    }
  }
}
